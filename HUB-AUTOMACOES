fn_requisitos() {
    cpu_modelo=$(grep -m1 "model name" /proc/cpuinfo | cut -d: -f2 | sed 's/^ //' | cut -c1-35)
    cpu_nucleos=$(nproc)
    read cpu_idle1 cpu_total1 < <(awk '/^cpu / {idle=$5; total=0; for(i=2;i<=NF;i++) total+=$i; print idle, total}' /proc/stat)
    sleep 1
    read cpu_idle2 cpu_total2 < <(awk '/^cpu / {idle=$5; total=0; for(i=2;i<=NF;i++) total+=$i; print idle, total}' /proc/stat)
    cpu_uso=$(awk "BEGIN {d_idle=$cpu_idle2-$cpu_idle1; d_total=$cpu_total2-$cpu_total1; if(d_total>0) printf \"%.0f\", (1-(d_idle/d_total))*100; else print 0}")

    ram_total=$(awk '/MemTotal/ {printf "%.1f", $2/1024/1024}' /proc/meminfo)
    ram_livre=$(awk '/MemAvailable/ {printf "%.1f", $2/1024/1024}' /proc/meminfo)
    ram_usada=$(awk '/MemTotal/{t=$2} /MemAvailable/{a=$2} END{printf "%.1f", (t-a)/1024/1024}' /proc/meminfo)

    disco_total=$(df -h / | awk 'NR==2 {print $2}')
    disco_usado=$(df -h / | awk 'NR==2 {print $3}')
    disco_livre=$(df -h / | awk 'NR==2 {print $4}')
    disco_pct=$(df / | awk 'NR==2 {print $5}')

    whiptail --title "Requisitos da Maquina" --msgbox \
"PROCESSADOR
  Modelo  : $cpu_modelo
  Nucleos : $cpu_nucleos
  Uso     : ${cpu_uso}%

MEMORIA RAM
  Total   : ${ram_total} GB
  Em uso  : ${ram_usada} GB
  Livre   : ${ram_livre} GB

ARMAZENAMENTO (/)
  Total   : $disco_total
  Em uso  : $disco_usado ($disco_pct)
  Livre   : $disco_livre" 22 55
}

fn_tcpdump() {
    which tcpdump &>/dev/null || apt-get install -y tcpdump

    mapfile -t interfaces < <(ip link show | awk -F': ' '/^[0-9]+: / && !/lo/ {print $2}' | awk '{print $1}')
    local iface_opts=("any" "Todas as interfaces")
    for iface_item in "${interfaces[@]}"; do
        iface_opts+=("$iface_item" "")
    done

    iface=$(whiptail --title "tcpdump - Interface" \
        --menu "Selecione a interface:" 20 60 8 \
        "${iface_opts[@]}" \
        3>&1 1>&2 2>&3)
    [[ $? -ne 0 ]] && return 1

    proto=$(whiptail --title "tcpdump - Protocolo" \
        --menu "Selecione o protocolo:" 14 50 4 \
        "1" "Todos" \
        "2" "TCP" \
        "3" "UDP" \
        "4" "ICMP" \
        3>&1 1>&2 2>&3)
    [[ $? -ne 0 ]] && return 1

    porta=$(whiptail --title "tcpdump - Porta" \
        --inputbox "Porta (deixe vazio para ignorar):" 8 50 \
        3>&1 1>&2 2>&3)

    origem=$(whiptail --title "tcpdump - Origem" \
        --inputbox "IP ou host de origem (deixe vazio para ignorar):" 8 60 \
        3>&1 1>&2 2>&3)

    destino=$(whiptail --title "tcpdump - Destino" \
        --inputbox "IP ou host de destino (deixe vazio para ignorar):" 8 60 \
        3>&1 1>&2 2>&3)

    modo=$(whiptail --title "tcpdump - Modo" \
        --menu "Como deseja capturar:" 12 50 2 \
        "1" "Exibir no terminal" \
        "2" "Salvar em /tmp/captura.pcap" \
        3>&1 1>&2 2>&3)
    [[ $? -ne 0 ]] && return 1

    local filtro=""
    case "$proto" in
        2) filtro="tcp" ;;
        3) filtro="udp" ;;
        4) filtro="icmp" ;;
    esac

    [[ -n "$porta" ]] && filtro+="${filtro:+ and }port $porta"
    [[ -n "$origem" ]] && filtro+="${filtro:+ and }src host $origem"
    [[ -n "$destino" ]] && filtro+="${filtro:+ and }dst host $destino"

    local cmd="tcpdump -i $iface -n"
    [[ -n "$filtro" ]] && cmd+=" '$filtro'"
    [[ "$modo" == "2" ]] && cmd+=" -w /tmp/captura.pcap"

    whiptail --title "tcpdump" --msgbox "Iniciando captura. Pressione Ctrl+C para encerrar.\n\nComando: $cmd" 10 70

    eval "$cmd"

    [[ "$modo" == "2" ]] && whiptail --title "Concluido" --msgbox "Captura salva em /tmp/captura.pcap" 8 50
}

