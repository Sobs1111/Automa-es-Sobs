fn_adicionar_usuario() {
    nome=$(whiptail --title "Adicionar Usuario" \
        --inputbox "Nome do novo usuario:" 8 50 \
        3>&1 1>&2 2>&3)
    [[ $? -ne 0 || -z "$nome" ]] && return 1

    senha=$(whiptail --title "Adicionar Usuario" \
        --passwordbox "Senha para $nome:" 8 50 \
        3>&1 1>&2 2>&3)
    [[ $? -ne 0 || -z "$senha" ]] && return 1

    nivel=$(whiptail --title "Adicionar Usuario - Permissao" \
        --menu "Selecione o nivel de permissao:" 14 60 3 \
        "1" "Usuario padrao (sem privilegios extras)" \
        "2" "Sudo com senha" \
        "3" "Sudo sem senha" \
        3>&1 1>&2 2>&3)
    [[ $? -ne 0 ]] && return 1

    if id "$nome" &>/dev/null; then
        whiptail --title "Erro" --msgbox "Usuario '$nome' ja existe." 8 50
        return 1
    fi

    useradd -m -s /bin/bash "$nome"
    echo "$nome:$senha" | chpasswd

    case "$nivel" in
        2)
            usermod -aG sudo "$nome"
            ;;
        3)
            usermod -aG sudo "$nome"
            echo "$nome ALL=(ALL) NOPASSWD:ALL" > /etc/sudoers.d/$nome
            chmod 0440 /etc/sudoers.d/$nome
            ;;
    esac

    local desc
    case "$nivel" in
        1) desc="Usuario padrao" ;;
        2) desc="Sudo com senha" ;;
        3) desc="Sudo sem senha" ;;
    esac

    whiptail --title "Concluido" --msgbox "Usuario criado com sucesso.\n\n  Usuario    : $nome\n  Permissao  : $desc" 10 50
}

fn_requisitos() {
