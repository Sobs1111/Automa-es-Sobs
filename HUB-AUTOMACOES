fn_verificar_bloqueio() {
    which dig &>/dev/null || apt-get install -y dnsutils

    while true; do
        dominio=$(whiptail --title "Verificar Bloqueio DNS" \
            --inputbox "Informe o dominio a verificar:\n(ex: facebook.com)" 10 60 \
            3>&1 1>&2 2>&3)
        [[ $? -ne 0 ]] && return 1
        [[ -z "$dominio" ]] && {
            whiptail --title "Erro" --msgbox "Dominio nao pode ser vazio." 8 40
            continue
        }
        break
    done

    whiptail --title "Verificar Bloqueio DNS" \
        --yesno "Deseja ver todos os dominios relacionados\nque contenham \"$dominio\"?" 9 60
    local busca_ampla=$?

    local resultado_grep resultado_dig bloqueado_grep=0 bloqueado_dig=0

    if [[ $busca_ampla -eq 0 ]]; then
        resultado_grep=$(grep -rF "${dominio}" /etc/unbound/ 2>/dev/null)
    else
        resultado_grep=$(grep -rF "\"${dominio}" /etc/unbound/ 2>/dev/null)
    fi

    if echo "$resultado_grep" | grep -q "127.0.0.1\|::\b"; then
        bloqueado_grep=1
    fi

    resultado_dig=$(dig @127.0.0.1 "$dominio" A +time=3 +tries=1 2>/dev/null)
    if echo "$resultado_dig" | grep -qP "^\S+\s+\d+\s+IN\s+A\s+127\.0\.0\.1"; then
        bloqueado_dig=1
    fi

    if [[ $busca_ampla -eq 0 ]]; then
        local dominios_lista secao_config msg_titulo
        msg_titulo="Dominios relacionados a: $dominio"

        dominios_lista=$(echo "$resultado_grep" | grep "local-zone:" | grep -oP '(?<=")[^"]+(?=")' | sort -u)

        if [[ -z "$dominios_lista" ]]; then
            secao_config="  (nenhum dominio relacionado encontrado)"
        else
            secao_config=""
            while IFS= read -r d; do
                local z i4 i6
                z=$(echo "$resultado_grep"  | grep "local-zone:"  | grep "\"$d\""  | awk '{print $NF}' | head -1)
                i4=$(echo "$resultado_grep" | grep "local-data:"  | grep "\"$d "   | grep -oP '\d+\.\d+\.\d+\.\d+' | head -1)
                i6=$(echo "$resultado_grep" | grep "AAAA"         | grep "\"$d "   | grep -oP '(?<=AAAA )[^"]+' | head -1)
                local linha="  $d"
                [[ -n "$z"  ]] && linha+="  [${z}]"
                [[ -n "$i4" ]] && linha+="  A:${i4}"
                [[ -n "$i6" ]] && linha+="  AAAA:${i6}"
                secao_config+="$linha\n"
            done <<< "$dominios_lista"
        fi

        local total
        total=$(echo "$dominios_lista" | grep -c .)

        clear
        echo "======================================================"
        echo " Busca por: $dominio"
        echo " Total    : $total dominio(s) encontrado(s)"
        echo "======================================================"
        echo ""
        printf "  %-45s %-12s %-15s %s\n" "DOMINIO" "ZONA" "IPv4" "IPv6"
        echo "  ----------------------------------------------------------------------------"
        while IFS= read -r d; do
            local z i4 i6
            z=$(echo "$resultado_grep"  | grep "local-zone:" | grep "\"$d\""  | awk '{print $NF}' | head -1)
            i4=$(echo "$resultado_grep" | grep "local-data:" | grep "\"$d "   | grep -oP '\d+\.\d+\.\d+\.\d+' | head -1)
            i6=$(echo "$resultado_grep" | grep "AAAA"        | grep "\"$d "   | grep -oP '(?<=AAAA )[^"]+' | head -1)
            printf "  %-45s %-12s %-15s %s\n" "$d" "${z:--}" "${i4:--}" "${i6:--}"
        done <<< "$dominios_lista"
        echo ""
        read -rp "Pressione Enter para voltar ao menu..."
        return 0
    fi

    if [[ $bloqueado_grep -eq 1 && $bloqueado_dig -eq 1 ]]; then
        status="BLOQUEADO"
    elif [[ $bloqueado_grep -eq 1 ]]; then
        status="BLOQUEADO (config sem confirmacao do dig)"
    elif [[ $bloqueado_dig -eq 1 ]]; then
        status="BLOQUEADO (dig confirma, sem entrada na config)"
    else
        status="NAO BLOQUEADO"
    fi

    local secao_config
    if [[ -n "$resultado_grep" ]]; then
        local zone_type ipv4_addr ipv6_addr
        zone_type=$(echo "$resultado_grep" | grep "local-zone:" | awk '{print $NF}' | sort -u | head -1)
        ipv4_addr=$(echo "$resultado_grep" | grep "local-data:" | grep -oP '\d+\.\d+\.\d+\.\d+' | sort -u | head -1)
        ipv6_addr=$(echo "$resultado_grep" | grep "AAAA" | grep -oP '(?<=AAAA )[^"]+' | sort -u | head -1)
        secao_config=""
        [[ -n "$zone_type" ]] && secao_config+="  Zona  : $zone_type\n"
        [[ -n "$ipv4_addr" ]] && secao_config+="  IPv4  : $ipv4_addr\n"
        [[ -n "$ipv6_addr" ]] && secao_config+="  IPv6  : $ipv6_addr"
        [[ -z "$secao_config" ]] && secao_config="  (nenhuma entrada encontrada)"
    else
        secao_config="  (nenhuma entrada encontrada)"
    fi

    local secao_dig
    secao_dig=$(echo "$resultado_dig" | awk '
        /^;; ANSWER SECTION:/ { found=1; next }
        found && /^;;/        { found=0 }
        found && NF           { printf "  %-35s %s\n", $1, $NF }
    ')
    [[ -z "$secao_dig" ]] && secao_dig="  (sem resposta na ANSWER SECTION)"

    local msg
    msg="Dominio : $dominio
Status  : $status

--- Config Unbound (/etc/unbound/) ---

$secao_config

--- Resposta DNS (dig @127.0.0.1 $dominio A) ---

$secao_dig"

    whiptail --title "Verificar Bloqueio: $dominio" \
        --msgbox "$msg" 26 72
}

_benchmark_ioping_verdict() {
    local avg_raw avg_num avg_unit avg_us verdict
    avg_raw=$(echo "$1" | grep "min/avg/max/mdev" | sed 's/.*=\s*//' | awk -F'/' '{print $2}' | xargs)
    avg_num=$(echo "$avg_raw" | awk '{print $1}')
    avg_unit=$(echo "$avg_raw" | awk '{print $2}')

    case "$avg_unit" in
        us) avg_us=$(printf "%.0f" "$avg_num") ;;
        ms) avg_us=$(printf "%.0f" "$(echo "$avg_num * 1000" | bc)") ;;
        s)  avg_us=$(printf "%.0f" "$(echo "$avg_num * 1000000" | bc)") ;;
        *)  avg_us=999999 ;;
    esac

    if   (( avg_us < 1000  )); then verdict="Excelente  - latencia muito baixa (tipico de SSD NVMe)"
    elif (( avg_us < 5000  )); then verdict="Bom        - latencia adequada (SSD SATA ou NVMe virtualizado)"
    elif (( avg_us < 20000 )); then verdict="Regular    - latencia moderada (HDD ou storage virtualizado)"
    else                            verdict="Ruim       - latencia alta, verificar I/O do storage"
    fi

    echo "  Latencia media : ${avg_raw:-n/a}"
    echo "  Avaliacao      : $verdict"
}

_benchmark_fio_verdict() {
    local read_bw write_bw read_iops write_iops ref_int verdict

    read_bw=$(echo   "$1" | grep -i "read:"  | grep -oP 'BW=\K[\d.]+(?=MiB)' | head -1)
    write_bw=$(echo  "$1" | grep -i "write:" | grep -oP 'BW=\K[\d.]+(?=MiB)' | head -1)
    read_iops=$(echo "$1" | grep -i "read:"  | grep -oP 'IOPS=\K[\w.]+' | head -1)
    write_iops=$(echo "$1" | grep -i "write:" | grep -oP 'IOPS=\K[\w.]+' | head -1)

    ref_int=$(printf "%.0f" "${read_bw:-0}" 2>/dev/null || echo 0)

    if   (( ref_int > 500 )); then verdict="Excelente  - throughput alto (NVMe ou storage de alta performance)"
    elif (( ref_int > 200 )); then verdict="Bom        - throughput adequado (SSD SATA ou NVMe virtualizado)"
    elif (( ref_int > 50  )); then verdict="Regular    - throughput moderado (HDD rapido ou storage compartilhado)"
    else                           verdict="Ruim       - throughput baixo, verificar storage"
    fi

    echo "  Leitura  : ${read_bw:-n/a} MiB/s  |  IOPS: ${read_iops:-n/a}"
    echo "  Escrita  : ${write_bw:-n/a} MiB/s  |  IOPS: ${write_iops:-n/a}"
    echo "  Avaliacao: $verdict"
}

fn_benchmark_disco() {
    local ferramenta
    ferramenta=$(whiptail --title "Benchmark de Disco" \
        --menu "Selecione o tipo de teste:" 14 65 3 \
        "1" "ioping  - Teste de latencia de disco" \
        "2" "fio     - Teste de leitura e escrita em disco" \
        "3" "Ambos" \
        3>&1 1>&2 2>&3)
    [[ $? -ne 0 ]] && return 1

    clear
    local tmp
    tmp=$(mktemp)

    if [[ "$ferramenta" == "1" || "$ferramenta" == "3" ]]; then
        which ioping &>/dev/null || apt-get install -y ioping
        echo "======================================================"
        echo " ioping - Teste de Latencia de Disco"
        echo "======================================================"
        echo ""
        echo ">>> Leitura (8k x 10 amostras)"
        ioping -c 10 -s 8k . 2>&1 | tee "$tmp"
        local ioping_read; ioping_read=$(cat "$tmp")
        echo ""
        echo ">>> Escrita (8k x 10 amostras)"
        ioping -c 10 -s 8k -W . 2>&1 | tee "$tmp"
        local ioping_write; ioping_write=$(cat "$tmp")
        echo ""
        echo "------------------------------------------------------"
        echo " RESULTADO ioping"
        echo "------------------------------------------------------"
        echo " Leitura:"
        _benchmark_ioping_verdict "$ioping_read"
        echo ""
        echo " Escrita:"
        _benchmark_ioping_verdict "$ioping_write"
        echo ""
    fi

    if [[ "$ferramenta" == "2" || "$ferramenta" == "3" ]]; then
        which fio &>/dev/null || apt-get install -y fio
        echo "======================================================"
        echo " fio - Teste de Leitura e Escrita em Disco"
        echo " 4 jobs | blocos 128k | arquivo 1G | duracao 1 min"
        echo "======================================================"
        echo ""
        fio --name=benchmark --filename=/tmp/fio_iotest \
            --rw=readwrite --ioengine=libaio --bs=128k \
            --numjobs=4 --size=1G --runtime=1m \
            --time_based --direct=1 \
            --status-interval=5 --output=/tmp/fio_result.txt
        local fio_out; fio_out=$(cat /tmp/fio_result.txt 2>/dev/null)
        rm -f /tmp/fio_iotest /tmp/fio_result.txt
        echo ""
        echo "------------------------------------------------------"
        echo " RESULTADO fio"
        echo "------------------------------------------------------"
        _benchmark_fio_verdict "$fio_out"
        echo ""
    fi

    rm -f "$tmp"
    read -rp "Pressione Enter para voltar ao menu..."
}

