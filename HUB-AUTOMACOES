    nome=$(whiptail --title "Adicionar Usuario" \
        --inputbox "Nome do novo usuario:" 8 50 \
        3>&1 1>&2 2>&3)
    [[ $? -ne 0 || -z "$nome" ]] && return 1

    senha=$(whiptail --title "Adicionar Usuario" \
        --passwordbox "Senha para $nome:" 8 50 \
        3>&1 1>&2 2>&3)
    [[ $? -ne 0 || -z "$senha" ]] && return 1

    nivel=$(whiptail --title "Adicionar Usuario - Permissao" \
