        sed -i '/^REDIRECT_PORT_80=/c\REDIRECT_PORT_80=0' /etc/nperf/nperf-server.conf
        sed -i '/^REDIRECT_PORT_443=/c\REDIRECT_PORT_443=0' /etc/nperf/nperf-server.conf

