    ram_livre=$(awk '/MemAvailable/ {printf "%.1f", $2/1024/1024}' /proc/meminfo)
    ram_usada=$(awk '/MemTotal/{t=$2} /MemAvailable/{a=$2} END{printf "%.1f", (t-a)/1024/1024}' /proc/meminfo)

    disco_total=$(df -h / | awk 'NR==2 {print $2}')
    disco_usado=$(df -h / | awk 'NR==2 {print $3}')
    disco_livre=$(df -h / | awk 'NR==2 {print $4}')
