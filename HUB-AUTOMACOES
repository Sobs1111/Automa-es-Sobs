#!/bin/bash

if [[ $EUID -ne 0 ]]; then
    echo "Este script precisa ser executado como root"
    exit 1
fi

is_private_ip() {
    local ip=$1
    [[ "$ip" =~ ^10\. ]] && return 0
    [[ "$ip" =~ ^192\.168\. ]] && return 0
    [[ "$ip" =~ ^172\.(1[6-9]|2[0-9]|3[01])\. ]] && return 0
    return 1
}

detectar_ips() {
    mapfile -t ipv4_list < <(ip -4 addr show | awk '/inet / {print $2}' | cut -d/ -f1)
    mapfile -t ipv6_list < <(ip -6 addr show | awk '/inet6 / {print $2}' | cut -d/ -f1 | grep -v '^fe80')
}

confirmar_ips() {
    detectar_ips
    local msg="Enderecos detectados:\n\nIPv4:\n"
    for ip in "${ipv4_list[@]}"; do msg+="  $ip\n"; done
    msg+="\nIPv6:\n"
    for ip in "${ipv6_list[@]}"; do msg+="  $ip\n"; done
    msg+="\nDeseja prosseguir com esses enderecos?"
    whiptail --title "Enderecos Detectados" --yesno "$msg" 20 60
    [[ $? -ne 0 ]] && return 1
    return 0
}

detectar_tier() {
    cpu_count=$(nproc)
    ram_gb=$(awk '/MemTotal/ {printf "%d", $2/1024/1024}' /proc/meminfo)

    if (( cpu_count <= 4 )); then tier_cpu="baixo"
    elif (( cpu_count <= 10 )); then tier_cpu="medio"
    else tier_cpu="alto"; fi

    if (( ram_gb < 6 )); then tier_ram="baixo"
    elif (( ram_gb <= 16 )); then tier_ram="medio"
    else tier_ram="alto"; fi

    tier_order() { case $1 in baixo) echo 1;; medio) echo 2;; alto) echo 3;; esac; }

    if (( $(tier_order "$tier_cpu") < $(tier_order "$tier_ram") )); then
        tier="$tier_cpu"
    else
        tier="$tier_ram"
    fi

    echo "Hardware detectado: ${cpu_count} vCPU | ${ram_gb} GB RAM"
    echo "Faixa de otimizacao aplicada: ${tier}"

    case "$tier" in
        baixo)
            t_threads=2; t_slabs=2; t_rrset="512m"; t_msg="256m"
            t_range=1024; t_qpt=1024; t_otcp=256; t_itcp=512
            ;;
        medio)
            t_threads=8; t_slabs=4; t_rrset="2g"; t_msg="1g"
            t_range=6144; t_qpt=4096; t_otcp=1024; t_itcp=2048
            ;;
        alto)
            t_threads=16; t_slabs=8; t_rrset="4g"; t_msg="2g"
            t_range=8192; t_qpt=8192; t_otcp=2048; t_itcp=4096
            ;;
    esac
}

instalar_unbound_base() {
    apt install rsyslog ssh net-tools dnsutils unbound -y

    mkdir -p /etc/unbound/unbound.conf.d

    cat > /etc/unbound/unbound.conf <<EOF
include-toplevel: "/etc/unbound/unbound.conf.d/*.conf"
EOF

    cat > /etc/unbound/acl.conf <<EOF
access-control: ::/0 allow
access-control: 0.0.0.0/0 allow
EOF

    touch /etc/unbound/blacklist.conf
    touch /etc/unbound/local_zone.conf
}

gerar_config_unbound() {
    local outgoing_ip="$1"
    config_file="/etc/unbound/unbound.conf.d/server.conf"
    {
        echo "server:"
        echo "    use-syslog: yes"
        echo "    username: \"unbound\""
        echo "    directory: \"/etc/unbound\""
        echo "    do-ip6: yes"
        echo "    do-ip4: yes"
        for ip in "${ipv4_list[@]}"; do echo "    interface: $ip"; done
        for ip in "${ipv6_list[@]}"; do echo "    interface: $ip"; done
        echo "    verbosity: 0"
        echo "    port: 53"
        echo "    log-replies: no"
        echo "    root-hints: /usr/share/dns/root.hints"
        echo "    harden-dnssec-stripped: yes"
        echo "    extended-statistics: yes"
        echo "    statistics-cumulative: no"
        echo "    include: /etc/unbound/local_zone.conf"
        echo "    include: /etc/unbound/blacklist.conf"
        echo "    include: /etc/unbound/acl.conf"
        echo "    num-threads: $t_threads"
        echo "    msg-cache-slabs: $t_slabs"
        echo "    rrset-cache-slabs: $t_slabs"
        echo "    infra-cache-slabs: $t_slabs"
        echo "    key-cache-slabs: $t_slabs"
        echo "    rrset-cache-size: $t_rrset"
        echo "    msg-cache-size: $t_msg"
        echo "    outgoing-range: $t_range"
        echo "    so-rcvbuf: 4m"
        echo "    so-sndbuf: 4m"
        echo "    so-reuseport: yes"
        echo "    prefetch: yes"
        echo "    prefetch-key: yes"
        echo "    hide-identity: yes"
        echo "    hide-version: yes"
        echo "    unwanted-reply-threshold: 10000000"
        echo "    deny-any: yes"
        echo "    num-queries-per-thread: $t_qpt"
        echo "    outgoing-num-tcp: $t_otcp"
        echo "    incoming-num-tcp: $t_itcp"
        echo "    minimal-responses: yes"
        echo "    edns-buffer-size: 1232"
        [[ -n "$outgoing_ip" ]] && echo "    outgoing-interface: $outgoing_ip"
    } > "$config_file"
}

aplicar_sysctl() {
    cat > /etc/sysctl.d/99-unbound.conf <<EOF
net.core.rmem_max = 134217728
net.core.wmem_max = 134217728
net.core.rmem_default = 16777216
net.core.wmem_default = 16777216
net.ipv4.tcp_rmem = 4096 87380 16777216
net.ipv4.tcp_wmem = 4096 65536 16777216
net.core.netdev_max_backlog = 32768
net.core.somaxconn = 4096
net.ipv4.udp_mem = 8388608 12582912 16777216
net.ipv4.udp_rmem_min = 16384
net.ipv4.udp_wmem_min = 16384
net.ipv4.ip_local_port_range = 10000 65535
net.ipv4.tcp_fastopen = 3
net.ipv4.tcp_tw_reuse = 1
vm.swappiness = 10
fs.file-max = 2097152
net.ipv6.conf.all.forwarding = 0
net.ipv6.conf.default.forwarding = 0
EOF
    sysctl -p /etc/sysctl.d/99-unbound.conf
}

fn_monitor_unbound_silencioso() {
    cat > /usr/local/bin/monitor_unbound.sh <<'MONITOR'
#!/bin/bash
SERVICE="unbound"
LOG_FILE="/var/log/monitor_unbound.log"
MAX_RESTARTS=3
WINDOW_SECONDS=900
CHECK_INTERVAL=120
RESTART_TIMESTAMPS=()

log() {
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] $1" | tee -a "$LOG_FILE"
}

purge_old_timestamps() {
    local now
    now=$(date +%s)
    local fresh=()
    for ts in "${RESTART_TIMESTAMPS[@]}"; do
        (( now - ts < WINDOW_SECONDS )) && fresh+=("$ts")
    done
    RESTART_TIMESTAMPS=("${fresh[@]}")
}

is_healthy() {
    local state
    state=$(systemctl is-active "$SERVICE" 2>/dev/null)
    [[ "$state" == "active" || "$state" == "running" ]]
}

try_restart() {
    purge_old_timestamps
    local count=${#RESTART_TIMESTAMPS[@]}
    if (( count >= MAX_RESTARTS )); then
        log "AVISO: limite de $MAX_RESTARTS restarts em ${WINDOW_SECONDS}s atingido. Restart bloqueado."
        return 1
    fi
    log "Reiniciando $SERVICE (restart $((count + 1)) de $MAX_RESTARTS na janela atual)..."
    if systemctl restart "$SERVICE"; then
        RESTART_TIMESTAMPS+=("$(date +%s)")
        log "Servico $SERVICE reiniciado com sucesso."
    else
        RESTART_TIMESTAMPS+=("$(date +%s)")
        log "ERRO: falha ao reiniciar $SERVICE. Verifique manualmente."
    fi
}

log "=========================================="
log "Monitor iniciado | intervalo: ${CHECK_INTERVAL}s | max restarts: ${MAX_RESTARTS}/${WINDOW_SECONDS}s"
log "=========================================="

while true; do
    if is_healthy; then
        log "OK: $SERVICE esta ativo e saudavel."
    else
        STATE=$(systemctl is-active "$SERVICE" 2>/dev/null)
        log "ALERTA: $SERVICE esta com estado '$STATE'. Tentando restart..."
        try_restart
    fi
    sleep "$CHECK_INTERVAL"
done
MONITOR

    cat > /etc/systemd/system/monitor-unbound.service <<EOF
[Unit]
Description=Monitor do servico Unbound
After=network.target unbound.service

[Service]
Type=simple
ExecStart=/usr/local/bin/monitor_unbound.sh
Restart=always
RestartSec=10
User=root

[Install]
WantedBy=multi-user.target
EOF

    chmod +x /usr/local/bin/monitor_unbound.sh
    systemctl daemon-reload
    systemctl enable --now monitor-unbound
}

fn_instalar_recursivo() {
    confirmar_ips || return

    outgoing_ip=""
    default_gw=$(ip route show default | awk '/default via/ {print $3; exit}')

    if [[ -n "$default_gw" ]] && is_private_ip "$default_gw"; then
        mapfile -t public_ipv4s < <(ip -4 addr show | awk '/inet / {print $2}' | cut -d/ -f1 | while read -r ip; do
            { is_private_ip "$ip" || [[ "$ip" =~ ^127\. ]]; } && continue
            echo "$ip"
        done)

        if [[ ${#public_ipv4s[@]} -gt 0 ]]; then
            local pub_opts=()
            for pub_ip in "${public_ipv4s[@]}"; do
                pub_opts+=("$pub_ip" "")
            done
            outgoing_ip=$(whiptail --title "Outgoing Interface" \
                --menu "Gateway privado detectado ($default_gw).\nSelecione o IP publico para outgoing-interface:" 20 60 8 \
                "${pub_opts[@]}" \
                3>&1 1>&2 2>&3)
            [[ $? -ne 0 ]] && return 1
        fi
    fi

    instalar_unbound_base
    detectar_tier
    gerar_config_unbound "$outgoing_ip"
    aplicar_sysctl
    fn_monitor_unbound_silencioso
    systemctl restart unbound
    whiptail --title "Concluido" --msgbox "Unbound recursivo instalado e configurado.\nServico de monitoramento instalado automaticamente." 10 60
    pos_dns
}

fn_reverso() {
    if ! systemctl is-active --quiet unbound 2>/dev/null; then
        whiptail --title "Aviso" --msgbox "Unbound nao detectado. Sera executada a instalacao base antes de configurar a zona reversa." 10 60
        confirmar_ips || return
        outgoing_ip=""
        instalar_unbound_base
        detectar_tier
        gerar_config_unbound "$outgoing_ip"
        aplicar_sysctl
    else
        detectar_ips
    fi

    fn_monitor_unbound_silencioso
    whiptail --title "Aviso" --msgbox "Servico de monitoramento do Unbound instalado automaticamente." 8 60

    OUTPUT="/etc/unbound/local_zone.conf"

    ip2int() {
        local a b c d
        IFS=. read -r a b c d <<< "$1"
        echo $(( (a << 24) | (b << 16) | (c << 8) | d ))
    }

    expand_ipv6() {
        local ip="$1"
        if [[ "$ip" == *"::"* ]]; then
            local left="${ip%%::*}"
            local right="${ip##*::}"
            local left_count=0 right_count=0
            [[ -n "$left" ]]  && left_count=$(awk -F: '{print NF}' <<< "$left")
            [[ -n "$right" ]] && right_count=$(awk -F: '{print NF}' <<< "$right")
            local missing=$(( 8 - left_count - right_count ))
            local zeros=""
            for ((i=0; i<missing; i++)); do zeros="${zeros}0000:"; done
            [[ -n "$left" ]]  && ip="${left}:${zeros}" || ip="${zeros}"
            [[ -n "$right" ]] && ip="${ip}${right}"    || ip="${ip%:}"
        fi
        local expanded=""
        IFS=: read -ra groups <<< "$ip"
        for g in "${groups[@]}"; do
            expanded="${expanded}$(printf '%04x' "0x${g}"):"
        done
        echo "${expanded%:}"
    }

    ipv6_reverse_zone() {
        local flat="${1//:}"
        local nibbles=$(( $2 / 4 ))
        local prefix="${flat:0:$nibbles}"
        local rev=""
        for ((i=${#prefix}-1; i>=0; i--)); do rev="${rev}${prefix:$i:1}."; done
        echo "${rev}ip6.arpa."
    }

    declare -a cidrs
    while true; do
        cidr=$(whiptail --title "Zona Reversa IPv4" \
            --inputbox "Bloco IPv4 CIDR (ex: 192.168.0.0/22)\nDeixe vazio para finalizar:" 10 60 \
            3>&1 1>&2 2>&3)
        [[ $? -ne 0 || -z "$cidr" ]] && break
        cidrs+=("$cidr")
    done

    domain=$(whiptail --title "Zona Reversa" \
        --inputbox "Dominio padrao (ex: provedor.com.br):" 10 60 \
        3>&1 1>&2 2>&3)
    [[ $? -ne 0 ]] && return 1

    declare -A special_ips
    while true; do
        sip=$(whiptail --title "IPs Especiais" \
            --inputbox "IP especial com hostname personalizado\nDeixe vazio para finalizar:" 10 60 \
            3>&1 1>&2 2>&3)
        [[ $? -ne 0 || -z "$sip" ]] && break
        shost=$(whiptail --title "IPs Especiais" \
            --inputbox "Hostname para $sip:" 10 60 \
            3>&1 1>&2 2>&3)
        [[ $? -ne 0 ]] && break
        special_ips["$sip"]="$shost"
    done

    ipv6_cidr=$(whiptail --title "Zona Reversa IPv6" \
        --inputbox "Prefixo IPv6 com mascara (ex: 2001:db8::/32)\nDeixe vazio para ignorar:" 10 60 \
        3>&1 1>&2 2>&3)

    declare -A ipv6_special
    ipv6_zone=""
    if [[ -n "$ipv6_cidr" ]]; then
        ipv6_addr="${ipv6_cidr%/*}"
        ipv6_len="${ipv6_cidr#*/}"
        ipv6_expanded=$(expand_ipv6 "$ipv6_addr")
        ipv6_zone=$(ipv6_reverse_zone "$ipv6_expanded" "$ipv6_len")
        whiptail --title "Zona IPv6" --msgbox "Zona IPv6 gerada: $ipv6_zone" 8 60
        while true; do
            sip6=$(whiptail --title "IPs IPv6 Especiais" \
                --inputbox "IPv6 especial com hostname personalizado\nDeixe vazio para finalizar:" 10 60 \
                3>&1 1>&2 2>&3)
            [[ $? -ne 0 || -z "$sip6" ]] && break
            shost6=$(whiptail --title "IPs IPv6 Especiais" \
                --inputbox "Hostname para $sip6:" 10 60 \
                3>&1 1>&2 2>&3)
            [[ $? -ne 0 ]] && break
            ipv6_special["$sip6"]="$shost6"
        done
    fi

    > "$OUTPUT"
    current_24=""

    for cidr in "${cidrs[@]}"; do
        ip_part="${cidr%/*}"
        prefix="${cidr#*/}"
        mask=$(( (0xFFFFFFFF << (32 - prefix)) & 0xFFFFFFFF ))
        start=$(( $(ip2int "$ip_part") & mask ))
        end=$(( start | (~mask & 0xFFFFFFFF) ))

        for (( i=start; i<=end; i++ )); do
            a=$(( (i >> 24) & 255 ))
            b=$(( (i >> 16) & 255 ))
            c=$(( (i >> 8)  & 255 ))
            d=$(( i & 255 ))
            current_ip="${a}.${b}.${c}.${d}"
            this_24="${a}.${b}.${c}"

            if [[ "$this_24" != "$current_24" ]]; then
                [[ -n "$current_24" ]] && echo "" >> "$OUTPUT"
                echo "#---------------------------------ZONA ${this_24}------------------------------------" >> "$OUTPUT"
                echo "" >> "$OUTPUT"
                echo "local-zone: \"${c}.${b}.${a}.in-addr.arpa.\" transparent" >> "$OUTPUT"
                echo "local-data: \"${c}.${b}.${a}.in-addr.arpa 10800 IN SOA hostmaster. nobody.invalid. 1 3600 1200 604800 10800\"" >> "$OUTPUT"
                echo "" >> "$OUTPUT"
                current_24="$this_24"
            fi

            if [[ -n "${special_ips[$current_ip]}" ]]; then
                hostname="${special_ips[$current_ip]}"
            else
                hostname="${a}-${b}-${c}-${d}.${domain}"
            fi

            echo "local-data-ptr: \"${current_ip} ${hostname}\"" >> "$OUTPUT"
        done
    done

    if [[ -n "$ipv6_zone" ]]; then
        {
            echo ""
            echo "#===========================================ZONA REVERSA IPv6========================================="
            echo ""
            echo "local-zone: \"${ipv6_zone}\" transparent"
            echo "local-data: \"${ipv6_zone%.} 10800 IN SOA hostmaster. nobody.invalid. 1 3600 1200 604800 10800\""
            echo ""
        } >> "$OUTPUT"
        for sip6 in "${!ipv6_special[@]}"; do
            echo "local-data-ptr: \"${sip6} ${ipv6_special[$sip6]}\"" >> "$OUTPUT"
        done
    fi

    if unbound-checkconf > /dev/null 2>&1; then
        systemctl restart unbound
        whiptail --title "Concluido" --msgbox "Arquivo gerado: $OUTPUT\nUnbound reiniciado com sucesso." 10 60
    else
        local erros
        erros=$(unbound-checkconf 2>&1)
        whiptail --title "Erro de Configuracao" --msgbox "$erros" 20 70
    fi

    pos_dns
}

fn_monitor_unbound() {
    fn_monitor_unbound_silencioso
    whiptail --title "Concluido" --msgbox "Servico de monitoramento do Unbound instalado e ativado." 8 60
}

fn_iptables() {
    local contexto="$1"

    apt install iptables iptables-persistent -y

    declare -a ssh_origins
    while true; do
        ssh_src=$(whiptail --title "iptables - SSH" \
            --inputbox "Origem permitida para SSH (CIDR ou IP)\nDeixe vazio para finalizar:" 10 60 \
            3>&1 1>&2 2>&3)
        [[ $? -ne 0 || -z "$ssh_src" ]] && break
        ssh_origins+=("$ssh_src")
    done

    iptables -F
    iptables -P INPUT DROP
    iptables -P FORWARD DROP
    iptables -P OUTPUT ACCEPT

    iptables -A INPUT -i lo -j ACCEPT
    iptables -A INPUT -m state --state RELATED,ESTABLISHED -j ACCEPT
    iptables -A INPUT -p icmp -j ACCEPT
    iptables -A OUTPUT -p icmp -j ACCEPT

    for src in "${ssh_origins[@]}"; do
        iptables -A INPUT -p tcp -s "$src" --dport 22 -j ACCEPT
    done

    case "$contexto" in
        dns)
            iptables -A INPUT -p tcp --dport 53 -j ACCEPT
            iptables -A INPUT -p udp --dport 53 -j ACCEPT
            ;;
        rpki)
            iptables -A INPUT -p tcp --dport 3000 -j ACCEPT
            iptables -A INPUT -p tcp --dport 8323 -j ACCEPT
            iptables -A INPUT -p tcp --dport 3323 -j ACCEPT
            ;;
    esac

    if systemctl is-active --quiet zabbix-agent2 2>/dev/null; then
        zabbix_src=$(whiptail --title "iptables - Zabbix" \
            --inputbox "Origem para porta 10050 do Zabbix (CIDR ou IP):" 10 60 \
            3>&1 1>&2 2>&3)
        if [[ $? -eq 0 && -n "$zabbix_src" ]]; then
            iptables -A INPUT -p tcp -s "$zabbix_src" --dport 10050 -j ACCEPT
            iptables -A INPUT -p udp -s "$zabbix_src" --dport 10050 -j ACCEPT
        fi
    fi

    netfilter-persistent save
    whiptail --title "Concluido" --msgbox "Regras de iptables aplicadas e salvas." 8 50
}

preparar_zabbix() {
    if dpkg -l zabbix-agent 2>/dev/null | grep -q '^ii'; then
        whiptail --title "Zabbix" --msgbox "zabbix-agent (v1) detectado. Sera removido antes da instalacao do zabbix-agent2." 8 60
        apt remove zabbix-agent -y
        apt autoremove -y
    fi

    if dpkg -l zabbix-agent2 2>/dev/null | grep -q '^ii'; then
        whiptail --title "Zabbix" --msgbox "zabbix-agent2 ja esta instalado. Sera feita apenas a configuracao." 8 60
        return 0
    fi

    apt install zabbix-agent2 -y
}

fn_zabbix_comum() {
    preparar_zabbix
    sys_hostname=$(hostname)

    local conf="/etc/zabbix/zabbix_agent2.conf"

    if [[ ! -f "$conf" ]]; then
        mkdir -p /etc/zabbix/zabbix_agent2.d
        cat > "$conf" <<EOF
PidFile=/var/run/zabbix/zabbix_agent2.pid
LogFile=/var/log/zabbix/zabbix_agent2.log
LogFileSize=0
Server=0.0.0.0/0
ServerActive=127.0.0.1
Hostname=${sys_hostname}
Include=/etc/zabbix/zabbix_agent2.d/*.conf
EOF
    else
        sed -i "s/^Server=.*/Server=0.0.0.0\/0/" "$conf"
        sed -i "s/^Hostname=.*/Hostname=${sys_hostname}/" "$conf"
    fi

    systemctl enable --now zabbix-agent2
    systemctl restart zabbix-agent2
    whiptail --title "Concluido" --msgbox "Zabbix Agent2 configurado.\nHostname: ${sys_hostname}" 8 60
}

fn_zabbix_unbound() {
    fn_zabbix_comum

    cat > /etc/unbound/unbound.conf.d/statistics-enable.conf <<EOF
server:
    statistics-interval: 0
    statistics-cumulative: no
    extended-statistics: yes

remote-control:
    control-enable: yes
    control-interface: 127.0.0.1
    control-port: 8953
    server-key-file: "/etc/unbound/unbound_server.key"
    server-cert-file: "/etc/unbound/unbound_server.pem"
    control-key-file: "/etc/unbound/unbound_control.key"
    control-cert-file: "/etc/unbound/unbound_control.pem"
EOF

    unbound-control-setup

    apt install sudo -y

    cat > /etc/sudoers.d/zabbix-agent <<EOF
Defaults:zabbix !requiretty
zabbix ALL = NOPASSWD: /usr/sbin/unbound-control
EOF

    chmod 0440 /etc/sudoers.d/zabbix-agent
    usermod -a -G unbound zabbix

    cat > /etc/zabbix/zabbix_agent2.d/userparameter_unbound.conf <<'EOF'
UserParameter=unbound.service,systemctl is-active unbound >/dev/null 2>&1 && echo 1 || echo 0
UserParameter=unbound.service.status,systemctl status unbound --no-pager -l 2>/dev/null | head -3 | tail -1 | awk '{print $2}' || echo "unknown"
UserParameter=unbound.time.up,sudo /usr/sbin/unbound-control stats_noreset | grep "time.up=" | cut -d= -f2
UserParameter=unbound.time.now,sudo /usr/sbin/unbound-control stats_noreset | grep "time.now=" | cut -d= -f2
UserParameter=unbound.time.elapsed,sudo /usr/sbin/unbound-control stats_noreset | grep "time.elapsed=" | cut -d= -f2
UserParameter=unbound.num.cachehits,sudo /usr/sbin/unbound-control stats_noreset | grep "num.cachehits=" | cut -d= -f2
UserParameter=unbound.num.cachemiss,sudo /usr/sbin/unbound-control stats_noreset | grep "num.cachemiss=" | cut -d= -f2
UserParameter=unbound.cache.hitrate,sudo /usr/sbin/unbound-control stats_noreset | awk '/num.cachehits=/{h=$2} /num.cachemiss=/{m=$2} END{total=h+m; if(total>0) printf "%.2f", (h/total)*100; else print 0}' FS='='
UserParameter=unbound.cache.size,sudo /usr/sbin/unbound-control stats_noreset | grep "msg.cache.count=" | cut -d= -f2
UserParameter=unbound.rrset.cache.size,sudo /usr/sbin/unbound-control stats_noreset | grep "rrset.cache.count=" | cut -d= -f2
UserParameter=unbound.mem.total,sudo /usr/sbin/unbound-control stats_noreset | awk '/^mem\./{sum += $2} END{print sum}' FS='='
UserParameter=unbound.mem.cache,sudo /usr/sbin/unbound-control stats_noreset | grep "mem.cache.message=" | cut -d= -f2
UserParameter=unbound.mem.cache.rrset,sudo /usr/sbin/unbound-control stats_noreset | grep "mem.cache.rrset=" | cut -d= -f2
