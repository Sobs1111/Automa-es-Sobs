fn_rpki() {
    echo "=== Configurando timezone para UTC ==="
    timedatectl set-timezone UTC

    echo "=== Atualizando repositorios e instalando dependencias ==="
    apt update
    apt install -y \
        ca-certificates \
        curl \
        gnupg \
        lsb-release \
        wget \
        gnupg2 \
        apt-transport-https \
        net-tools \
        iptables

    echo "=== Adicionando repositorio NLnet Labs ==="
    curl -fsSL https://packages.nlnetlabs.nl/aptkey.asc | gpg --dearmor -o /usr/share/keyrings/nlnetlabs-archive-keyring.gpg

    echo \
"deb [arch=$(dpkg --print-architecture) signed-by=/usr/share/keyrings/nlnetlabs-archive-keyring.gpg] https://packages.nlnetlabs.nl/linux/debian \
$(lsb_release -cs) main" | tee /etc/apt/sources.list.d/nlnetlabs.list > /dev/null

    apt update

    echo "=== Instalando Krill ==="
    apt install -y krill krillup krillta

    echo "=== Instalando Routinator ==="
    apt install -y routinator

    systemctl enable krill
    systemctl enable routinator

    echo "=== Configurando Krill ==="
    cp /etc/krill.conf /etc/krill.conf.orig

    if grep -q "ip = " /etc/krill.conf; then
        sed -i 's/ip = .*"/ip = "0.0.0.0"/' /etc/krill.conf
    else
        echo 'ip = "0.0.0.0"' >> /etc/krill.conf
    fi

    echo "=== Configurando Routinator ==="
    if [ -f /etc/routinator/routinator.conf ]; then
        cp /etc/routinator/routinator.conf /etc/routinator/routinator.conf.orig

        sed -i 's/^rtr-listen = \["127.0.0.1:3323"\]/#rtr-listen = ["127.0.0.1:3323"]/' /etc/routinator/routinator.conf
        sed -i 's/^http-listen = \["127.0.0.1:8323"\]/#http-listen = ["127.0.0.1:8323"]/' /etc/routinator/routinator.conf

        grep -q 'rtr-listen = \[ "\[::\]:3323" \]' /etc/routinator/routinator.conf || \
            echo 'rtr-listen = [ "[::]:3323" ]' >> /etc/routinator/routinator.conf

        grep -q 'http-listen = \[ "\[::\]:8323" \]' /etc/routinator/routinator.conf || \
            echo 'http-listen = [ "[::]:8323" ]' >> /etc/routinator/routinator.conf
    else
        echo "AVISO: Arquivo de configuracao do Routinator nao encontrado."
    fi

    echo "=== Executando routinator vrps (pode levar alguns minutos) ==="
    routinator vrps

    systemctl start krill
    systemctl restart routinator

    TOKEN=$(grep "token =" /etc/krill.conf | cut -d'"' -s -f2)

    whiptail --title "Instalacao Concluida - RPKI" --msgbox \
"Krill e Routinator instalados com sucesso.\n
Krill
  Interface web : https://[seu-ip]:3000
  Token         : ${TOKEN}\n
Routinator
  HTTP API      : http://[seu-ip]:8323
  RTR           : [seu-ip]:3323" 16 65

    whiptail --title "iptables" --yesno "Deseja configurar o iptables?" 8 50
    [[ $? -eq 0 ]] && fn_iptables "rpki"
}

fn_rota_persistente() {
    mapfile -t interfaces < <(ip link show | awk -F': ' '/^[0-9]+: / && !/lo/ {print $2}' | awk '{print $1}')

    local iface_opts=()
    for iface_item in "${interfaces[@]}"; do
        iface_opts+=("$iface_item" "")
    done

    iface=$(whiptail --title "Rota Persistente" \
        --menu "Selecione a interface de rede:" 20 60 8 \
        "${iface_opts[@]}" \
        3>&1 1>&2 2>&3)
    [[ $? -ne 0 ]] && return 1

    mapfile -t gateways_priv < <(ip route show dev "$iface" | awk '/via/ {print $3}' | sort -u)

    if [[ ${#gateways_priv[@]} -eq 0 ]]; then
        whiptail --title "Erro" --msgbox "Nenhum gateway detectado na interface $iface." 8 50
        return 1
    fi

    local gw_opts=()
    for gw_item in "${gateways_priv[@]}"; do
        gw_opts+=("$gw_item" "")
    done

    gateway=$(whiptail --title "Rota Persistente" \
        --menu "Selecione o gateway privado:" 20 60 8 \
        "${gw_opts[@]}" \
        3>&1 1>&2 2>&3)
    [[ $? -ne 0 ]] && return 1

    mapfile -t ips_disponiveis < <(ip -4 addr show | awk '/inet / {print $2}' | cut -d/ -f1 | grep -v '^127\.')

    if [[ ${#ips_disponiveis[@]} -eq 0 ]]; then
        whiptail --title "Erro" --msgbox "Nenhum IP encontrado na interface $iface." 8 50
        return 1
    fi

    local ip_opts=()
    for ip_item in "${ips_disponiveis[@]}"; do
        ip_opts+=("$ip_item" "")
    done

    src_ip=$(whiptail --title "Rota Persistente" \
        --menu "Selecione o IP de origem publico (src):" 20 60 8 \
        "${ip_opts[@]}" \
        3>&1 1>&2 2>&3)
    [[ $? -ne 0 ]] && return 1

    whiptail --title "Rota Persistente - Confirmacao" \
        --yesno "Confirmar configuracao?\n\n  Interface : $iface\n  Gateway   : $gateway\n  IP origem : $src_ip" 12 50
    [[ $? -ne 0 ]] && return 1

    cat > /usr/local/bin/rota_persistente.sh << EOF
#!/bin/bash
ip route del default dev $iface
ip route add default via $gateway dev $iface src $src_ip
EOF

    chmod +x /usr/local/bin/rota_persistente.sh

    cat > /etc/systemd/system/rota-persistente.service << EOF
[Unit]
Description=Rota persistente com IP de origem
After=network.target

[Service]
Type=oneshot
TimeoutStartSec=60
ExecStartPre=/bin/bash -c 'until ip route show | grep -q "$gateway"; do sleep 2; done'
ExecStart=/usr/local/bin/rota_persistente.sh
RemainAfterExit=yes

[Install]
WantedBy=multi-user.target
EOF

    systemctl daemon-reload
    systemctl enable --now rota-persistente

    if systemctl is-active --quiet rota-persistente; then
        whiptail --title "Concluido" --msgbox "Rota persistente configurada e servico ativado com sucesso.\n\n  Interface : $iface\n  Gateway   : $gateway\n  IP origem : $src_ip" 12 60
    else
        whiptail --title "Atencao" --msgbox "Rota configurada, porem o servico nao iniciou. Verifique com:\nsystemctl status rota-persistente" 10 60
    fi
}

