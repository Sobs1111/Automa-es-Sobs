  Livre   : $disco_livre" 22 60
}

fn_tcpdump() {
    which tcpdump &>/dev/null || apt-get install -y tcpdump

    mapfile -t interfaces < <(ip link show | awk -F': ' '/^[0-9]+: / && !/lo/ {print $2}' | awk '{print $1}')
    local iface_opts=("any" "Todas as interfaces")
    for iface_item in "${interfaces[@]}"; do
        iface_opts+=("$iface_item" "")
    done

    iface=$(whiptail --title "tcpdump - Interface" \
        --menu "Selecione a interface:" 20 60 8 \
        "${iface_opts[@]}" \
        3>&1 1>&2 2>&3)
    [[ $? -ne 0 ]] && return 1

    proto=$(whiptail --title "tcpdump - Protocolo" \
        --menu "Selecione o protocolo:" 14 50 4 \
        "1" "Todos" \
        "2" "TCP" \
        "3" "UDP" \
        "4" "ICMP" \
        3>&1 1>&2 2>&3)
    [[ $? -ne 0 ]] && return 1

    porta=$(whiptail --title "tcpdump - Porta" \
        --inputbox "Porta (deixe vazio para ignorar):" 8 50 \
        3>&1 1>&2 2>&3)

    origem=$(whiptail --title "tcpdump - Origem" \
        --inputbox "IP ou host de origem (deixe vazio para ignorar):" 8 60 \
        3>&1 1>&2 2>&3)

    destino=$(whiptail --title "tcpdump - Destino" \
        --inputbox "IP ou host de destino (deixe vazio para ignorar):" 8 60 \
        3>&1 1>&2 2>&3)

    modo=$(whiptail --title "tcpdump - Modo" \
        --menu "Como deseja capturar:" 12 50 2 \
        "1" "Exibir no terminal" \
        "2" "Salvar em /tmp/captura.pcap" \
        3>&1 1>&2 2>&3)
    [[ $? -ne 0 ]] && return 1

    local filtro=""
    case "$proto" in
        2) filtro="tcp" ;;
        3) filtro="udp" ;;
        4) filtro="icmp" ;;
    esac

    [[ -n "$porta" ]] && filtro+="${filtro:+ and }port $porta"
    [[ -n "$origem" ]] && filtro+="${filtro:+ and }src host $origem"
    [[ -n "$destino" ]] && filtro+="${filtro:+ and }dst host $destino"

    local cmd="tcpdump -i $iface -n"
    [[ -n "$filtro" ]] && cmd+=" '$filtro'"
    [[ "$modo" == "2" ]] && cmd+=" -w /tmp/captura.pcap"

    whiptail --title "tcpdump" --msgbox "Iniciando captura. Pressione Ctrl+C para encerrar.\n\nComando: $cmd" 10 70

    eval "$cmd"

    [[ "$modo" == "2" ]] && whiptail --title "Concluido" --msgbox "Captura salva em /tmp/captura.pcap" 8 50
}

fn_status_servicos() {
    local msg=""

    while IFS= read -r linha; do
        svc=$(echo "$linha" | awk '{print $1}' | sed 's/\.service//')
        status=$(echo "$linha" | awk '{print $3}')
        msg+="$(printf '%-35s %s\n' "$svc" "$status")"$'\n'
    done < <(systemctl list-units --type=service --no-legend --no-pager 2>/dev/null)

    whiptail --title "Status dos Servicos" --msgbox "$msg" 30 70
}

fn_reiniciar_servico() {
    local opts=()

    while IFS= read -r linha; do
        svc=$(echo "$linha" | awk '{print $1}' | sed 's/\.service//')
        opts+=("$svc" "")
    done < <(systemctl list-units --type=service --state=active --no-legend --no-pager 2>/dev/null)

    if [[ ${#opts[@]} -eq 0 ]]; then
        whiptail --title "Reiniciar Servico" --msgbox "Nenhum servico ativo encontrado." 8 50
        return 1
    fi

    svc=$(whiptail --title "Reiniciar Servico" \
        --menu "Selecione o servico para reiniciar:" 20 60 12 \
        "${opts[@]}" \
        3>&1 1>&2 2>&3)
    [[ $? -ne 0 ]] && return 1

    systemctl restart "$svc"

    if systemctl is-active --quiet "$svc"; then
        whiptail --title "Concluido" --msgbox "Servico '$svc' reiniciado com sucesso." 8 55
    else
        whiptail --title "Erro" --msgbox "Falha ao reiniciar '$svc'.\nVerifique com: systemctl status $svc" 10 60
    fi
}

fn_remover_usuario() {
    mapfile -t usuarios < <(awk -F: '$3 >= 1000 && $1 != "nobody" {print $1}' /etc/passwd)

    if [[ ${#usuarios[@]} -eq 0 ]]; then
        whiptail --title "Remover Usuario" --msgbox "Nenhum usuario comum encontrado." 8 50
        return 1
    fi

    local opts=()
    for u in "${usuarios[@]}"; do
        opts+=("$u" "")
    done

    nome=$(whiptail --title "Remover Usuario" \
        --menu "Selecione o usuario a remover:" 20 50 8 \
        "${opts[@]}" \
        3>&1 1>&2 2>&3)
    [[ $? -ne 0 ]] && return 1

    whiptail --title "Remover Usuario" \
        --yesno "Deseja remover tambem o diretorio home de '$nome'?" 8 55
    local remover_home=$?

    whiptail --title "Confirmacao" \
        --yesno "Confirmar remocao do usuario '$nome'?" 8 50
    [[ $? -ne 0 ]] && return 1

    if [[ $remover_home -eq 0 ]]; then
        userdel -r "$nome" 2>/dev/null
    else
        userdel "$nome" 2>/dev/null
    fi

    rm -f /etc/sudoers.d/"$nome"

    whiptail --title "Concluido" --msgbox "Usuario '$nome' removido com sucesso." 8 50
}

fn_gerencia_usuarios() {
    while true; do
        choice=$(whiptail --title "Gerencia de Usuarios" \
            --menu "Selecione uma opcao:" 14 50 4 \
            "1" "Adicionar Usuario" \
            "2" "Remover Usuario" \
            "3" "Alterar Senha" \
            "4" "Voltar" \
            3>&1 1>&2 2>&3)

        [[ $? -ne 0 ]] && return 0

        case "$choice" in
            1) fn_adicionar_usuario ;;
            2) fn_remover_usuario ;;
            3) fn_alterar_senha ;;
            4) return 0 ;;
        esac
    done
}

fn_alterar_senha() {
    mapfile -t usuarios < <(awk -F: '$3 >= 1000 && $1 != "nobody" {print $1}' /etc/passwd)

    if [[ ${#usuarios[@]} -eq 0 ]]; then
        whiptail --title "Alterar Senha" --msgbox "Nenhum usuario comum encontrado." 8 50
        return 1
    fi

    local opts=()
    for u in "${usuarios[@]}"; do
        opts+=("$u" "")
    done

    nome=$(whiptail --title "Alterar Senha" \
        --menu "Selecione o usuario:" 20 50 8 \
        "${opts[@]}" \
        3>&1 1>&2 2>&3)
    [[ $? -ne 0 ]] && return 1

    senha=$(whiptail --title "Alterar Senha" \
        --passwordbox "Nova senha para '$nome':" 8 50 \
        3>&1 1>&2 2>&3)
    [[ $? -ne 0 || -z "$senha" ]] && return 1

    echo "$nome:$senha" | chpasswd
    whiptail --title "Concluido" --msgbox "Senha do usuario '$nome' alterada com sucesso." 8 55
}

