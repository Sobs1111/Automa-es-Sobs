        sed -i '/^TLS_PORT=/c\TLS_PORT=8443' /etc/init.d/nperf-server
        sed -i '/^REDIRECT_PORT_80=/c\REDIRECT_PORT_80=0' /etc/init.d/nperf-server
        sed -i '/^REDIRECT_PORT_443=/c\REDIRECT_PORT_443=0' /etc/init.d/nperf-server
    else
        sed -i '/^#BIND_IP=/c\BIND_IP="::"' /etc/nperf/nperf-server.conf
