IMPORTANTE: Anote a senha agora.
Ela nao sera exibida novamente." 16 55

    preparar_zabbix
    sys_hostname=$(hostname)
    local conf="/etc/zabbix/zabbix_agent2.conf"

    if [[ ! -f "$conf" ]]; then
        mkdir -p /etc/zabbix/zabbix_agent2.d
        cat > "$conf" <<EOF
PidFile=/var/run/zabbix/zabbix_agent2.pid
LogFile=/var/log/zabbix/zabbix_agent2.log
LogFileSize=0
Server=0.0.0.0/0
Hostname=${sys_hostname}
Include=/etc/zabbix/zabbix_agent2.d/*.conf
EOF
    else
        sed -i "s/^Server=.*/Server=0.0.0.0\/0/" "$conf"
        sed -i "s/^Hostname=.*/Hostname=${sys_hostname}/" "$conf"
    fi

    systemctl enable --now zabbix-agent2
    systemctl restart zabbix-agent2

    whiptail --title "Concluido - Zabbix Agent2" --msgbox \
"Zabbix Agent2 instalado e configurado.\n
  Hostname : ${sys_hostname}
  Server   : 0.0.0.0/0" 12 55

    fn_firewall_zabbix
}

fn_teste_dns() {
    which dig &>/dev/null || apt-get install -y dnsutils

    local dns_server="localhost"

    local tipo
    tipo=$(whiptail --title "Teste DNS Unbound" \
        --menu "Selecione o tipo de teste:" 12 60 3 \
        "1" "Todas as categorias" \
        "2" "Teste rapido (Bancos, Redes Sociais, Streaming)" \
        "3" "Personalizado" \
