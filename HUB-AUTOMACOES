fn_instalar_frr_anycast() {
    curl -s https://deb.frrouting.org/frr/keys.asc | \
        gpg --dearmor -o /usr/share/keyrings/frrouting-archive-keyring.gpg

    echo \
"deb [signed-by=/usr/share/keyrings/frrouting-archive-keyring.gpg] https://deb.frrouting.org/frr \
$(lsb_release -cs) frr-stable" | tee /etc/apt/sources.list.d/frr.list > /dev/null

    apt update
    apt install -y frr frr-doc frr-pythontools
    apt-mark hold frr frr-doc frr-pythontools
}

fn_configurar_frr_anycast() {
    sed -i 's/^ospfd=no/ospfd=yes/' /etc/frr/daemons
    sed -i 's/^ospf6d=no/ospf6d=yes/' /etc/frr/daemons

    cat > /etc/frr/frr.conf <<EOF
log syslog informational

frr defaults traditional
hostname ${hostname_frr}
no ip forwarding
no ipv6 forwarding
service integrated-vtysh-config
!
interface ${iface_ospf}
 ip ospf area 0
 ip ospf network point-to-point
 ipv6 ospf6 area 0
 ipv6 ospf6 network point-to-point
exit
!
interface lo
 ip ospf area 0
 ipv6 ospf6 area 0
exit
!
router ospf
 ospf router-id ${router_id}
exit
!
router ospf6
 ospf6 router-id ${router_id}
exit
EOF
    systemctl enable frr
    systemctl restart frr
}

fn_instalar_unbound_anycast() {
    mkdir -p /etc/unbound/unbound.conf.d
    mkdir -p /var/log/unbound
    touch /var/log/unbound/unbound.log
    chown -R unbound:unbound /var/log/unbound/

    cat > /etc/unbound/unbound.conf <<EOF
include: "/etc/unbound/unbound.conf.d/*.conf"
EOF
    touch /etc/unbound/blacklist.conf
    touch /etc/unbound/local_zone.conf
}

fn_configurar_unbound_anycast() {
    local slabs=4
    (( num_threads > 8 )) && slabs=8

    {
        echo "server:"
        echo "    verbosity: 1"
        echo "    statistics-interval: 0"
        echo "    statistics-cumulative: no"
        echo "    extended-statistics: yes"
        echo "    num-threads: $num_threads"
        echo "    serve-expired: yes"
        for ip in "${unbound_interfaces[@]}"; do echo "    interface: $ip"; done
        echo "    interface-automatic: no"
        [[ -n "$outgoing_ipv4" ]] && echo "    outgoing-interface: $outgoing_ipv4"
        [[ -n "$outgoing_ipv6" ]] && echo "    outgoing-interface: $outgoing_ipv6"
        echo "    outgoing-range: 8192"
        echo "    outgoing-num-tcp: 1024"
        echo "    incoming-num-tcp: 2048"
        echo "    so-rcvbuf: 8m"
        echo "    so-sndbuf: 8m"
        echo "    so-reuseport: yes"
        echo "    edns-buffer-size: 1232"
        echo "    msg-cache-size: 1g"
        echo "    msg-cache-slabs: $slabs"
        echo "    num-queries-per-thread: 4096"
        echo "    rrset-cache-size: 2g"
        echo "    rrset-cache-slabs: $slabs"
        echo "    infra-cache-slabs: $slabs"
        echo "    key-cache-slabs: $slabs"
        echo "    do-ip4: yes"
        echo "    do-ip6: yes"
        echo "    do-udp: yes"
        echo "    do-tcp: yes"
        echo "    chroot: \"\""
        echo "    username: \"unbound\""
        echo "    directory: \"/etc/unbound\""
        echo "    logfile: \"/var/log/unbound/unbound.log\""
        echo "    use-syslog: no"
        echo "    log-time-ascii: yes"
        echo "    log-queries: no"
        echo "    pidfile: \"/var/run/unbound.pid\""
        echo "    root-hints: \"/usr/share/dns/root.hints\""
        echo "    hide-identity: yes"
        echo "    hide-version: yes"
        echo "    unwanted-reply-threshold: 10000000"
        echo "    prefetch: yes"
        echo "    prefetch-key: yes"
        echo "    rrset-roundrobin: yes"
        echo "    minimal-responses: yes"
        echo "    module-config: \"respip validator iterator\""
        echo "    val-clean-additional: yes"
        echo "    val-log-level: 1"
        echo "    deny-any: yes"
        echo "    include: /etc/unbound/local_zone.conf"
        echo "    include: /etc/unbound/blacklist.conf"
        echo "    include: /etc/unbound/acl.conf"
    } > /etc/unbound/unbound.conf.d/server.conf

    {
        echo "access-control: 127.0.0.0/8 allow"
        echo "access-control: ::1/128 allow"
        if [[ $acl_redes_internas -eq 0 ]]; then
            echo "access-control: 100.64.0.0/10 allow"
            echo "access-control: 10.0.0.0/8 allow"
            echo "access-control: 172.16.0.0/12 allow"
            echo "access-control: 192.168.0.0/16 allow"
            echo "access-control: 169.254.0.0/16 allow"
            echo "access-control: fc00::/7 allow"
        fi
        for block in "${acl_blocks[@]}"; do echo "access-control: $block allow"; done
    } > /etc/unbound/acl.conf

    cat > /etc/unbound/unbound.conf.d/statistics-enable.conf <<EOF
server:
    statistics-interval: 0
    statistics-cumulative: no
    extended-statistics: yes

remote-control:
    control-enable: yes
    control-interface: 127.0.0.1
    control-port: 8953
    server-key-file: "/etc/unbound/unbound_server.key"
    server-cert-file: "/etc/unbound/unbound_server.pem"
    control-key-file: "/etc/unbound/unbound_control.key"
    control-cert-file: "/etc/unbound/unbound_control.pem"
EOF

    unbound-control-setup
    systemctl enable unbound
    systemctl restart unbound
}

